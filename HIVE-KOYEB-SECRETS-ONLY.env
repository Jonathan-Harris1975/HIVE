# HIVE Koyeb secrets-only environment
# Paste these in Koyeb. Non-secret settings live in HIVE-PRODUCTION-SHARED.env.
# Last reviewed: 22 June 2026

ADMIN_BEARER_TOKEN={{ secret.Hive_API_KEY }}
D1_API_KEY={{ secret.CF-database-hive-API }}
D1_DATABASE_ID={{ secret.D1_UUID }}
DATABASE_PASSWORD={{ secret.Database_PW }}
EMBEDDINGS_API_TOKEN={{ secret.CF_WORKERS_AI_API }}
OPENROUTER_API_KEY={{ secret.OPENROUTER_HIVE_API_KEY }}
OPS_EVENT_INGEST_TOKEN={{ secret.OPS_EVENT_INGEST_TOKEN }}
R2_ACCESS_KEY_ID={{ secret.R2_ACCESS_KEY_ID }}
R2_SECRET_ACCESS_KEY={{ secret.R2_SECRET_ACCESS_KEY }}
R2_READ_ACCESS_KEY_ID={{ secret.R2_READ_ACCESS_KEY_ID }}
R2_READ_SECRET_ACCESS_KEY={{ secret.R2_READ_SECRET_ACCESS_KEY }}
RMS_API_KEY={{ secret.RMS_API_KEY }}
VECTORIZE_API_TOKEN={{ secret.Vectorize_API_kEY }}
