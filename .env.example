# App
APP_NAME="JH Ops Chat"
APP_ENV=development
ADMIN_BEARER_TOKEN=change-me-local-only
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://jonathan-harris.online
OPENROUTER_APP_TITLE=JH Ops Chat
DEFAULT_MODEL=anthropic/claude-3.5-haiku
CHEAP_MODEL=google/gemini-flash-1.5
BALANCED_MODEL=anthropic/claude-3.5-haiku
PREMIUM_MODEL=anthropic/claude-3.7-sonnet
CODE_MODEL=anthropic/claude-3.7-sonnet
AUDIT_MODEL=anthropic/claude-3.7-sonnet

# Storage: Cloudflare R2 S3-compatible API
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=ops-chat-uploads
CF_R2_PUBLIC_BASE_URL=

# Metadata store
DATABASE_URL=sqlite+aiosqlite:///./local-data/jh_ops_chat.sqlite3

# Vector search: Cloudflare Vectorize adapter
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_VECTORIZE_INDEX=jh-ops-chat
CF_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5

# Upload safety
MAX_UPLOAD_BYTES=104857600
MAX_ZIP_FILES=5000
MAX_ZIP_UNCOMPRESSED_BYTES=524288000
