# App
APP_NAME="HIVE"
APP_ENV=development
APP_VERSION=1.26.4-production
ADMIN_BEARER_TOKEN=change-me-local-only
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example: ALLOWED_HOSTS=your-service.koyeb.app,api.example.com
ALLOWED_HOSTS=*
API_DOCS_ENABLED=false
SECURITY_HEADERS_ENABLED=true
REQUEST_LOGGING_ENABLED=true
TRUSTED_HOSTS_ENABLED=true
MAX_REQUEST_BODY_BYTES=115343360
PRODUCTION_REQUIRE_OPENROUTER=true
PRODUCTION_REQUIRE_R2=true
PRODUCTION_REQUIRE_DATABASE=false
READINESS_DEPENDENCY_PROBES_ENABLED=true
READINESS_DEPENDENCY_PROBE_CACHE_SECONDS=30
EXECUTION_ADAPTERS_ENABLED=true
EXECUTION_ADAPTERS_REQUIRE_APPROVAL=true

# Uvicorn/Koyeb runtime
WEB_CONCURRENCY=1
UVICORN_LIMIT_CONCURRENCY=32
UVICORN_BACKLOG=128
UVICORN_TIMEOUT_KEEP_ALIVE=10
UVICORN_TIMEOUT_GRACEFUL_SHUTDOWN=30
FORWARDED_ALLOW_IPS=*
LOG_LEVEL=info

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://jonathan-harris.online
OPENROUTER_APP_TITLE=JH Ops Chat
DEFAULT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
CHEAP_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
BALANCED_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
PREMIUM_MODEL=~anthropic/claude-sonnet-latest
CODE_MODEL=x-ai/grok-build-0.1
AUDIT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_FREE_FALLBACK_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
ALLOW_PAID_FALLBACK=false
OPENROUTER_MODEL_PREFLIGHT_ENABLED=true
OPENROUTER_MODEL_LIST_TIMEOUT_SECONDS=10
OPENROUTER_ATTEMPT_TIMEOUT_SECONDS=12
OPENROUTER_MAX_FALLBACK_ATTEMPTS=2
OPENROUTER_EMPTY_REPLY_RETRY_ENABLED=true
OPENROUTER_MIN_RESPONSE_TOKENS=80
CHAT_WITH_FILE_MODEL_TIMEOUT_SECONDS=30

# Storage: Cloudflare R2 S3-compatible API
# HIVE accepts either CF_R2_* or shorter R2_* names.
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=ops-chat-uploads
CF_R2_PUBLIC_BASE_URL=
CF_R2_ENDPOINT_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_UPLOADS=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT_URL=
R2_REGION=auto
R2_CONNECT_TIMEOUT_SECONDS=8
R2_READ_TIMEOUT_SECONDS=20
R2_MAX_ATTEMPTS=2
R2_ADDRESSING_STYLE=path
R2_MULTI_BUCKET_READ_ENABLED=false
R2_READ_ACCESS_KEY_ID=
R2_READ_SECRET_ACCESS_KEY=
R2_MULTI_BUCKET_MAX_SCAN_KEYS=5000
R2_DOWNLOAD_MAX_BYTES=536870912
# In production, omit to require every configured bucket lane or set an explicit governed subset.
R2_REQUIRED_READ_LANES=uploads,audits,art,blog,blog_images,blog_rss,brand_assets,meta,meta_system,podcast,podcast_rss,rss,transcripts,transcript_html,hive_skills

# v1.6 ecosystem R2 lane registry. These do not expose secrets. They let HIVE
# understand where AIMS/RAMS/website/podcast/skills artefacts live.
R2_BUCKET_ART=podcastart
R2_BUCKET_AUDITS=audits
R2_BUCKET_BLOG=blog
R2_BUCKET_BLOG_IMAGES=blog-images
R2_BUCKET_BLOG_RSS=rss-feed-blog
R2_BUCKET_BRAND_ASSETS=brand-assets
R2_BUCKET_META=podcast-meta
R2_BUCKET_META_SYSTEM=metasystem
R2_BUCKET_PODCAST=podcast
R2_BUCKET_PODCAST_RSS_FEEDS=podcast-rss-feeds
R2_BUCKET_RSS_FEEDS=rss-feeds
R2_BUCKET_TRANSCRIPTS=transcripts
R2_BUCKET_HIVE_SKILLS=hive-skills
R2_PUBLIC_BASE_URL_ART=https://podcast-coverart.jonathan-harris.online
R2_PUBLIC_BASE_URL_AUDITS=https://pub-f6b6cfd7d07e46f695d08e4a8dc3bd6b.r2.dev
R2_PUBLIC_BASE_URL_BLOG=https://pub-360fc5a1a8e844fcaa3d10d1d472b76c.r2.dev
R2_PUBLIC_BASE_URL_BLOG_IMAGES=https://pub-0990b7b0871040f8ac0b8c7f91f6c2b9.r2.dev
R2_PUBLIC_BASE_URL_BLOG_RSS=https://blog-rss.jonathan-harris.online/
R2_PUBLIC_BASE_URL_BRAND_ASSETS=https://assets.jonathan-harris.online
R2_PUBLIC_BASE_URL_META=https://pub-6ffbf3786149484b9bade99d21656ca7.r2.dev
R2_PUBLIC_BASE_URL_META_SYSTEM=https://pub-f1af4f6cf4c14d58abaf43112176431b.r2.dev
R2_PUBLIC_BASE_URL_PODCAST=https://podcast.jonathan-harris.online
R2_PUBLIC_BASE_URL_PODCAST_RSS=https://podcast-rss-feeds.jonathan-harris.online
R2_PUBLIC_BASE_URL_RSS=https://ai-news.jonathan-harris.online
R2_PUBLIC_BASE_URL_TRANSCRIPT=https://pub-2e4f201532854c01b157071c8b1fce8d.r2.dev
R2_PUBLIC_BASE_URL_TRANSCRIPT_HTML=https://pub-2e4f201532854c01b157071c8b1fce8d.r2.dev
R2_PUBLIC_BASE_URL_HIVE_SKILLS=https://pub-da50a6512f164566955a3076a1c795ef.r2.dev

# Optional semantic retrieval: Cloudflare Vectorize + Workers AI embeddings.
# Keep disabled until /v1/vectorize/diagnostics confirms the account/token/index.
VECTORIZE_ENABLED=false
VECTORIZE_ACCOUNT_ID=
VECTORIZE_API_TOKEN=
VECTORIZE_INDEX_NAME=hive-chunks
VECTORIZE_TIMEOUT_SECONDS=15
VECTORIZE_MAX_ATTEMPTS=2
VECTORIZE_TOP_K=8
VECTORIZE_RETURN_METADATA=all
EMBEDDINGS_ENABLED=false
EMBEDDINGS_PROVIDER=cloudflare
EMBEDDINGS_ACCOUNT_ID=
EMBEDDINGS_API_TOKEN=
EMBEDDINGS_MODEL=cf/baai/bge-base-en-v1.5
EMBEDDINGS_DIMENSIONS=768
EMBEDDINGS_TIMEOUT_SECONDS=20
EMBEDDINGS_MAX_BATCH_SIZE=32

# Upload safety
MAX_UPLOAD_BYTES=104857600
MAX_ZIP_FILES=5000
MAX_ZIP_UNCOMPRESSED_BYTES=524288000
MAX_FILE_READ_BYTES=2097152
MAX_FILE_CHAT_CHARS=24000
FILE_CHUNK_MAX_CHARS=4000
FILE_CHUNK_OVERLAP_CHARS=400
FILE_CHUNK_MAX_COUNT=500
FILE_RETRIEVAL_MAX_CHUNKS=6

# Optional SQL persistence for HIVE operational data.
# Use this for conversations, messages, file metadata, upload records and token/cost logs.
DATABASE_ENABLED=false
# Either provide DATABASE_URL or individual Koyeb/PostgreSQL fields.
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SSLMODE=require
DATABASE_CONNECT_TIMEOUT_SECONDS=8
DATABASE_STATEMENT_TIMEOUT_SECONDS=30

# Optional Cloudflare D1 metadata store.
# Use this for ecosystem metadata: audit run indexes, council report indexes,
# podcast episode indexes, ebook catalogue cache and social snapshots.
D1_ENABLED=false
D1_ACCOUNT_ID=
D1_API_KEY=
D1_DATABASE_ID=
D1_DATABASE_NAME=database-hive
D1_TIMEOUT_SECONDS=3
D1_MAX_ATTEMPTS=1

# v1.4 operational notes
# /health exposes build + storage flags. /healthz is a minimal MAST keep-awake endpoint.
# Use POST /v1/db/test-cleanup with dry_run=true before deleting smoke-test records.
# Rotate API tokens after accidental exposure and then update the matching Koyeb secret.

# Production ingestion controls. The limits remain bounded for safety, but the
# deployed HIVE service is not operating in free-tier mode.
HIVE_FREE_TIER_MODE=false
DOCUMENT_EXTRACT_MAX_CHARS=120000
DOCUMENT_EXTRACT_PDF_MAX_PAGES=40
DOCUMENT_EXTRACT_CSV_MAX_ROWS=2000
DOCUMENT_EXTRACT_XLSX_MAX_ROWS_PER_SHEET=500
DOCUMENT_EXTRACT_XLSX_MAX_SHEETS=12
DOCUMENT_EXTRACT_DOCX_MAX_TABLE_ROWS=2000
ZIP_EXTRACT_MAX_MEMBERS=80
ZIP_EXTRACT_MAX_MEMBER_BYTES=2097152
ZIP_EXTRACT_MAX_TOTAL_TEXT_CHARS=120000
ZIP_EXTRACT_MAX_DEPTH=2
ZIP_EXTRACT_SUPPORTED_SUFFIXES=.txt,.md,.log,.json,.csv,.html,.htm,.pdf,.docx,.xlsx

# v1.8 skill registry importer
SKILL_REGISTRY_IMPORT_MAX_ITEMS=250
SKILL_REGISTRY_IMPORT_TIMEOUT_SECONDS=6
SKILL_REGISTRY_MAX_SOURCE_BYTES=5242880
SKILL_REGISTRY_FALLBACK_ENABLED=true
SKILL_REGISTRY_FALLBACK_CACHE_SECONDS=300
SKILL_CONTEXT_ENABLED=true
SKILL_CONTEXT_MAX_ITEMS=2
SKILL_CONTEXT_MAX_CHARS=4000
SKILL_CONTEXT_RISK_CEILING=medium

# Central operational event inbox for GitHub, Koyeb, Cloudflare Pages and runtime alerts.
OPS_EVENT_INGEST_ENABLED=true
OPS_EVENT_INGEST_TOKEN={{ secret.OPS_EVENT_INGEST_TOKEN }}
OPS_EVENT_MEMORY_LIMIT=200

# Ecosystem health dashboard (authenticated HIVE endpoint)
REPO_HEALTH_ENABLED=true
REPO_HEALTH_TIMEOUT_SECONDS=6
REPO_HEALTH_CACHE_SECONDS=30
HIVE_UI_HEALTH_URL=https://hive.jonathan-harris.online/health
AIMS_HEALTH_URL=https://app.jonathan-harris.online/livez
AIMS_OPERATIONAL_HEALTH_URL=https://app.jonathan-harris.online/ops/health
RAMS_HEALTH_URL=https://mod.jonathan-harris.online/livez
RAMS_READINESS_URL=https://mod.jonathan-harris.online/readiness
RAMS_HEALTH_BEARER_TOKEN=
# MAST is a Koyeb Worker. Monitor its durable scheduler heartbeat in R2 rather
# than attempting to call public HTTP endpoints that a Worker does not expose.
MAST_MONITOR_MODE=r2
MAST_STATE_R2_LANE=meta_system
MAST_STATE_OBJECT_KEY=state/mast/scheduler-state.json
MAST_STATE_HEALTHY_MAX_AGE_SECONDS=90
MAST_STATE_DOWN_MAX_AGE_SECONDS=300
MAST_STATE_MAX_BYTES=1048576
IRS_HEALTH_URL=https://images.jonathan-harris.online/health.json
WEBSITE_HEALTH_URL=https://jonathan-harris.online/health.json
